; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project Lantern"
run/main_scene="res://ui/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

driver/enable_input=true
driver/mix_rate=48000

[autoload]

PocketBaseRESTManager="*res://core/managers/PocketBaseRESTManager.gd"
PocketBaseRPCManager="*res://core/managers/PocketBaseRPCManager.gd"
SessionService="*res://core/services/SessionService.gd"
InventoryService="*res://core/services/InventoryService.gd"
ItemService="*res://core/services/ItemService.gd"
NetworkService="*res://core/services/NetworkService.gd"
SceneService="*res://core/services/SceneService.gd"
TLSHelper="*res://core/helpers/TLSHelper.gd"
VoiceService="*res://core/services/VoiceService.gd"
NotificationService="*res://core/services/NotificationService.gd"

[editor]

run/main_run_args="set PB_SYSTEM_USER=server && set PB_SYSTEM_PASSWORD=RBdDKctr6hR8E6n"

